# rud1-desktop (Electron) environment variables. All are read from the OS
# environment by the main process (no .env loader is bundled) — this file just
# documents them.

# ── Test mode ────────────────────────────────────────────────────────────────
# RUD1_TEST_MODE=1 makes the app load a LOCAL rud1-es instead of production:
#   • main window    → http://<RUD1_TEST_HOST>:3000/dashboard
#   • update manifest→ http://<RUD1_TEST_HOST>:3000/desktop/manifest.json
#   • IPC allowlist  → adds http://<host>:3000 + localhost variants
# Absent/0/false = production (https://www.rud1.es), no behavior change.
# RUD1_TEST_HOST is the LAN IP/host of the dev machine running rud1-es
# (default: localhost).
# RUD1_TEST_MODE=1
# RUD1_TEST_HOST=192.168.1.50

# ── Explicit overrides (win over test mode) ──────────────────────────────────
# RUD1_APP_URL=http://192.168.1.50:3000/dashboard
# RUD1_VERSION_MANIFEST_URL=http://192.168.1.50:3000/desktop/manifest.json
# RUD1_APP_ORIGIN=http://192.168.1.50:3000   # comma-separated IPC origin allowlist
# RUD1_DEV_TOOLS=1                            # open devtools on launch
